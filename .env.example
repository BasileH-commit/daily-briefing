# Smily Briefing - Environment Variables Template
#
# IMPORTANT: This is just a template!
#
# To use locally:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your real tokens in .env
# 3. The .env file is in .gitignore so it won't be committed
#
# For GitHub Actions (production):
# - Don't use .env file
# - Add these as GitHub Secrets instead
# - Go to: Settings → Secrets and variables → Actions → New repository secret

# Anthropic (Claude) API Key
# Get it from: https://console.anthropic.com/ → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Jira API Token
# Get it from: https://id.atlassian.com/manage-profile/security/api-tokens
# Click "Create API token", name it "Daily Briefing Bot"
JIRA_API_TOKEN=your-jira-token-here

# Jira Email (your Jira account email)
JIRA_EMAIL=basile.hamon@smily.com

# Slack Bot Token
# Get it from: https://api.slack.com/apps → Your App → OAuth & Permissions
# Should start with "xoxb-"
# Required scopes: channels:history, groups:history, chat:write, conversations:read
SLACK_BOT_TOKEN=xoxb-your-slack-token-here
